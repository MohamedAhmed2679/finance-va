# Finance VA — Environment Variables
# Copy this to .env and fill in your actual values

# ==========================================
# SUPABASE (Required)
# ==========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...
VITE_AUTH_REDIRECT_URL=http://localhost:3000/

# ==========================================
# GOOGLE OAUTH (Optional — for Google Sign-In)
# ==========================================
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ==========================================
# MICROSOFT MSAL (Optional — for Microsoft 365 Sign-In)
# ==========================================
VITE_MSAL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ==========================================
# APPLE SIGN-IN (Optional — for Apple Sign-In)
# ==========================================
VITE_APPLE_CLIENT_ID=com.financeva.app.signin

# ==========================================
# CLOUDKIT (Optional — for iCloud Backup)
# ==========================================
VITE_CLOUDKIT_CONTAINER=iCloud.com.financeva.app
VITE_CLOUDKIT_API_TOKEN=your-cloudkit-api-token

# ==========================================
# EXCHANGE RATE API (Optional — for Currency Converter)
# ==========================================
VITE_EXCHANGE_API_KEY=your-exchange-rate-api-key
